# Copiar a `.env` en la raíz del repositorio (Docker Compose lee este archivo).
# Valores por defecto alineados con docker-compose.yml

POSTGRES_DB=girona_prod
POSTGRES_USER=girona_user
POSTGRES_PASSWORD=girona_pass_change_me
# Puerto que escucha Postgres en el HOST (psql: localhost:este_puerto). Debe coincidir con compose.
POSTGRES_HOST_PORT=25432
# Opcional: reutilizar datos de otro despliegue (`docker volume ls`). Si no se define, se usa girona_postgres_data.
# POSTGRES_DATA_VOLUME_NAME=girona-software-main_postgres_data

# API FastAPI en el HOST (Swagger: localhost:este_puerto/docs). Si 8000 está ocupado por
# docker-proxy o otro proceso, usa p. ej. 28000.
BACKEND_HOST_PORT=8000

# Backend (opcional; el compose ya define valores por defecto)
AUTO_CREATE_TABLES=1
AUTO_MIGRATE_SCHEMA=1
FACTUS_ENABLED=0

# Si usas facturación Factus, completa según girona-back/.env.example
# FACTUS_ENVIRONMENT=sandbox
# FACTUS_CLIENT_ID=
# FACTUS_CLIENT_SECRET=
